# ── Dependências — nunca versionadas ────────────────────────────────────────
node_modules/

# ── Logs do npm/yarn ─────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ── Arquivos de sistema ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editores/IDEs (temporários) ───────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json

# ── Variáveis de ambiente e segredos — nunca versionar ────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── Artefatos LOCAIS de build Android (android/ em si CONTINUA versionado) ───
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captures/
android/*.iml
android/.idea/

# ── Artefatos LOCAIS de build iOS (ios/ em si CONTINUA versionado) ───────────
ios/App/build/
ios/App/Pods/
ios/App/output/
ios/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
**/*.xcuserstate
**/xcuserdata/

# ── mobile/www/vendor/: builds UMD do Capacitor vendorizados manualmente,
#    DEVEM permanecer versionados (não são gerados por bundler nenhum aqui) ──
!mobile/www/vendor/
